# streetworks credentials template
#
# Copy this file to `.env` and fill in what you have. Every provider is
# optional - the quickstart and smoke test skip anything left blank.
# `.env` is gitignored; never commit real credentials.

# --- Street Manager (DfT) --------------------------------------------------
# Register: https://department-for-transport-streetmanager.github.io/street-manager-docs/
# SM_ENV: sandbox (default) or production
SM_EMAIL=
SM_PASSWORD=
SM_ENV=sandbox

# --- Geoplace DataVIA -------------------------------------------------------
# Basic auth (most accounts):
DATAVIA_USER=
DATAVIA_PASSWORD=
# ...or OAuth2 client credentials instead:
# DATAVIA_CLIENT_ID=
# DATAVIA_CLIENT_SECRET=
# A USRN you can see (used by the quickstart street lookup):
DATAVIA_USRN=

# --- D-TRO (DfT Digital Traffic Regulation Orders) ---------------------------
# Free consumer account: https://dtro-ui.dft.gov.uk (issues PRODUCTION creds)
# API Key -> DTRO_CLIENT_ID, API Secret -> DTRO_CLIENT_SECRET
DTRO_CLIENT_ID=
DTRO_CLIENT_SECRET=
DTRO_APP_ID=
# integration (default) or production. Consumer-portal accounts are
# production; reads there also need: STREETWORKS_ALLOW_PRODUCTION=1
DTRO_ENV=
# STREETWORKS_ALLOW_PRODUCTION=1

# --- SRWR Open Data (Scotland) -----------------------------------------------
# No credentials required. Optionally point at an already-downloaded archive
# so the tools parse locally instead of downloading:
# SRWR_ARCHIVE=

# --- OS Open USRN -------------------------------------------------------------
# No credentials required. The GeoPackage is ~300 MB; after downloading it
# once (see examples/openusrn_lookup.py), point here to enable local lookups:
# OPENUSRN_GPKG=osopenusrn_202607.gpkg
# OPENUSRN_TEST_USRN=33909869

# --- Street Manager Open Data (SNS push) --------------------------------------
# No credentials required - it's a push feed; you host the HTTPS endpoint.
# See examples/opendata_fastapi.py
